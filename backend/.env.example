# --- Backend environment variables ---
# Copy this file to `.env` and fill in real values.

# MongoDB connection string and database name
MONGO_URL=mongodb://localhost:27017
DB_NAME=app_stack

# Comma-separated list of allowed CORS origins (your frontend URL[s])
CORS_ORIGINS=http://localhost:3000

# Google Gemini API key (free tier from https://aistudio.google.com/apikey).
# Used for all AI generation.
GEMINI_API_KEY=

# Gemini model to use (optional; defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Stripe secret API key (server-side)
STRIPE_API_KEY=

# Stripe webhook signing secret (from Stripe Dashboard > Webhooks).
# Starts with whsec_...
STRIPE_WEBHOOK_SECRET=

# Google OAuth Web client ID (from Google Cloud Console > Credentials).
# MUST be identical to the frontend's REACT_APP_GOOGLE_CLIENT_ID.
# Looks like: 1234567890-abc123def456.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
