# --- Frontend environment variables ---
# Copy this file to `.env` and fill in real values.
# (Create React App only exposes vars prefixed with REACT_APP_.)

# Base URL of the backend API (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8001

# Google OAuth Web client ID (from Google Cloud Console > Credentials).
# MUST be identical to the backend's GOOGLE_CLIENT_ID.
# Looks like: 1234567890-abc123def456.apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=
